# ============================================================
# TEXLORE BACKEND — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# The server REFUSES TO BOOT if any required variable is missing.
# NEVER commit .env to version control.
# ============================================================

# --- Runtime ---
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# --- MongoDB Atlas (required) ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/texlore?retryWrites=true&w=majority

# --- JWT (required) ---
# Generate strong secrets: `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=replace-with-32-char-random-string

# --- Admin bootstrap (used by seed script only) ---
ADMIN_NAME=Texlore Administrator
ADMIN_EMAIL=texlorerugs@gmail.com
ADMIN_PASSWORD=ChangeThisStrongPassword!123
ADMIN_SECRET_KEY=replace-with-long-random-secret-key

# --- Cloudinary (required) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=texlore

# --- SMTP / Nodemailer (required) ---
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=texlorerugs@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=Texlore
SMTP_FROM_EMAIL=texlorerugs@gmail.com

# --- Razorpay (required) ---
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# --- Currency support ---
# INR is the base. USD via Razorpay International.
SUPPORTED_CURRENCIES=INR,USD
DEFAULT_CURRENCY=INR

# --- Security / Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=10

# --- OTP config ---
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_RESEND=3
OTP_RESEND_COOLDOWN_SECONDS=60

# --- Admin lockout ---
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15
