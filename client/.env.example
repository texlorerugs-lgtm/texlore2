# ============================================================
# TEXLORE CLIENT — Environment Variables
# ============================================================
# All VITE_* vars are inlined at build time. Never put secrets here.
# ============================================================

VITE_API_URL=http://localhost:5000/api/v1
VITE_APP_NAME=Texlore
VITE_DEFAULT_CURRENCY=INR
VITE_SUPPORTED_CURRENCIES=INR,USD

# Razorpay public key (safe to expose). SECRET key stays on server.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
